# ---------------------------------------------------------------------------
# Ingestion source: controls WHERE data is read FROM.
# Options: csv | mysql | json
# ---------------------------------------------------------------------------
SOURCE_TYPE=csv

# ---------------------------------------------------------------------------
# Destination (always SQLite — all writes go here regardless of SOURCE_TYPE)
# ---------------------------------------------------------------------------
SQLITE_DB_PATH=output/databases/individual/omop.sqlite3

# Output directory for exported files (export_tables.py)
EXPORT_DIR=output/exported

# ---------------------------------------------------------------------------
# Optional in .env for SOURCE_TYPE=csv  (directory containing source CSV files)
# You can also pass SOURCE_DIR at runtime for one-off runs.
# ---------------------------------------------------------------------------
# SOURCE_DIR=/path/to/csv_source_dir

# ---------------------------------------------------------------------------
# Required for SOURCE_TYPE=json
# ---------------------------------------------------------------------------
# JSON_SOURCE_PATH=/path/to/patient_demographics.json

# ---------------------------------------------------------------------------
# Required for SOURCE_TYPE=mysql  (READ-ONLY source — no writes go to MySQL)
# ---------------------------------------------------------------------------
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=omop
