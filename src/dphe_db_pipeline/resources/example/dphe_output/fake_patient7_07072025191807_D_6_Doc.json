stended, No HSM.\nEXT: Good pulses, No clubbing, cyanosis or edema\n\nIMPRESSION: \nPatient’s surgical management is now complete. She is to be seen by Medical Oncology to discuss systemic therapy. She also has an appointment to see Radiation Oncology for post-surgical radiation to the breast.\n","mentions":[{"begin":1105,"end":1130,"id":"fake_patient7_07072025191807_M_445","classUri":"ImmunosuppressiveTherapy","negated":false,"uncertain":false,"historic":true,"confidence":100},{"begin":1591,"end":1610,"id":"fake_patient7_07072025191807_M_480","classUri":"SurgicalManagement","negated":false,"uncertain":false,"historic":false,"confidence":100},{"begin":483,"end":485,"id":"fake_patient7_07072025191807_M_406","classUri":"ProgesteroneReceptorStatus","negated":false,"uncertain":false,"historic":true,"confidence":80},{"begin":1180,"end":1191,"id":"fake_patient7_07072025191807_M_450","classUri":"BoneMarrow","negated":false,"uncertain":false,"historic":true,"confidence":100},{"begin":613,"end":618,"id":"fake_patient7_07072025191807_M_417","classUri":"Lymph","negated":false,"uncertain":false,"historic":true,"confidence":80},{"begin":760,"end":767,"id":"fake_patient7_07072025191807_M_427","classUri":"Nuclear","negated":false,"uncertain":false,"historic":true,"confidence":100},{"begin":1402,"end":1405,"id":"fake_patient7_07072025191807_M_466","classUri":"Cancer_sl_TestisAntigen","negated":true,"uncertain":false,"historic":false,"confidence":40},{"begin":1784,"end":1790,"id":"fake_patient7_07072025191807_M_486","classUri":"Breast","negated":false,"uncertain":false,"historic":false,"confidence":90},{"begin":1149,"end":1152,"id":"fake_patient7_07072025191807_M_448","classUri":"SourceLeukocytes","negated":false,"uncertain":false,"historic":true,"confidence":40},{"begin":908,"end":918,"id":"fake_patient7_07072025191807_M_434","classUri":"Metastatic","negated":false,"uncertain":false,"historic":true,"confidence":100},{"begin":455,"end":461,"id":"fake_patient7_07072025191807_M_401","