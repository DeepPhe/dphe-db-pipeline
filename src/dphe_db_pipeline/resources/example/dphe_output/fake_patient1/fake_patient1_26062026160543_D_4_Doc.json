urmurs, rubs or gallops\nABD: Soft, non-tender, non-distended, No HSM.\nEXT: Good pulses, No clubbing, cyanosis or edema\n\nIMPRESSION: \nPatient has had a partial response to neoadjuvant chemotherapy for triple negative infiltrating ductal carcinoma of the right breast.\n","mentions":[{"begin":343,"end":372,"id":"fake_patient1_26062026160543_M_237","classUri":"InvasiveBreastCarcinomaOfNoSpecialType","negated":false,"uncertain":false,"historic":false,"confidence":100},{"begin":577,"end":583,"id":"fake_patient1_26062026160543_M_252","classUri":"Breast","negated":false,"uncertain":false,"historic":true,"confidence":90},{"begin":529,"end":539,"id":"fake_patient1_26062026160543_M_249","classUri":"MetastaticLesion","negated":false,"uncertain":false,"historic":true,"confidence":100},{"begin":1348,"end":1352,"id":"fake_patient1_26062026160543_M_292","classUri":"TEMPRegimen","negated":false,"uncertain":false,"historic":false,"confidence":51},{"begin":1756,"end":1761,"id":"fake_patient1_26062026160543_M_318","classUri":"Right","negated":false,"uncertain":false,"historic":false,"confidence":80},{"begin":1703,"end":1718,"id":"fake_patient1_26062026160543_M_315","classUri":"EstrogenReceptorStatus","negated":false,"uncertain":false,"historic":false,"confidence":80},{"begin":959,"end":971,"id":"fake_patient1_26062026160543_M_267","classUri":"Pharmacotherapy","negated":true,"uncertain":false,"historic":true,"confidence":100},{"begin":1157,"end":1165,"id":"fake_patient1_26062026160543_M_278","classUri":"Axilla","negated":false,"uncertain":false,"historic":true,"confidence":100},{"begin":1457,"end":1460,"id":"fake_patient1_26062026160543_M_298","classUri":"Cancer_sl_TestisAntigen","negated":true,"uncertain":false,"historic":false,"confidence":40},{"begin":393,"end":408,"id":"fake_patient1_26062026160543_M_241","classUri":"EstrogenReceptorStatus","negated":false,"uncertain":false,"historic":false,"confidence":80},{"begin":509,"end":528,"id":"fake_patient1_26062026160543_M_246","class