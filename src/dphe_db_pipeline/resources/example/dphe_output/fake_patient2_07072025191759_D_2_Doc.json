nancy.  The mass measures 1.3x3.2x5.1 cm.  Ultrasound core biopsy is recommended.\nAbnormal left axillary lymph nodes are highly suspicious of metastatic disease.\nMR evaluation of extent of disease is recommended.\nASSESSMENT AND RECOMMENDATIONS:\nACR BI-RADS Category: 5 (Breast Imaging Left) Highly suggestive for malignancy.\nRECOMMENDATION: Ultrasound guided core biopsy\nOVERALL ASSESSMENT: 5 (Highly suggestive for malignancy.\n","mentions":[{"begin":1760,"end":1766,"id":"fake_patient2_07072025191759_M_130","classUri":"Breast","negated":false,"uncertain":false,"historic":false,"confidence":90},{"begin":656,"end":664,"id":"fake_patient2_07072025191759_M_74","classUri":"Axilla","negated":false,"uncertain":false,"historic":false,"confidence":100},{"begin":1224,"end":1244,"id":"fake_patient2_07072025191759_M_105","classUri":"AxillaryLymphNode","negated":false,"uncertain":false,"historic":false,"confidence":100},{"begin":1233,"end":1238,"id":"fake_patient2_07072025191759_M_107","classUri":"Lymph","negated":false,"uncertain":false,"historic":false,"confidence":80},{"begin":1325,"end":1330,"id":"fake_patient2_07072025191759_M_111","classUri":"Lymph","negated":false,"uncertain":false,"historic":false,"confidence":80},{"begin":1586,"end":1606,"id":"fake_patient2_07072025191759_M_123","classUri":"AxillaryLymphNode","negated":false,"uncertain":false,"historic":false,"confidence":100},{"begin":523,"end":530,"id":"fake_patient2_07072025191759_M_67","classUri":"Breast","negated":false,"uncertain":false,"historic":false,"confidence":100},{"begin":1632,"end":1642,"id":"fake_patient2_07072025191759_M_128","classUri":"Metastatic","negated":false,"uncertain":true,"historic":false,"confidence":100},{"begin":413,"end":417,"id":"fake_patient2_07072025191759_M_55","classUri":"Left","negated":false,"uncertain":false,"historic":true,"confidence":60},{"begin":1632,"end":1650,"id":"fake_patient2_07072025191759_M_127","classUri":"MetastaticLesion","negated":false,"uncertain":true,"historic"